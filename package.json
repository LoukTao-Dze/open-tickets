{
  "name": "open-ticket",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start": "run-p start:frontend start:backend",
    "start:frontend": "npm run start --prefix package/frontend",
    "start:backend": "npm run start:dev --prefix package/backend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "test": "npm run test -w backend && npm run test -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "axios": "^1.18.1"
  }
}
